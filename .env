# RUNCHISE CONFIG
RUNCHISE_API_URL=https://api.runchise.com/v1
RUNCHISE_API_KEY=your_runchise_api_key
RUNCHISE_STORE_ID=your_store_id
MIN_ORDER_AMOUNT=30000

# MIKROTIK CONFIG
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASS=password
MIKROTIK_VOUCHER_DURATION=60m
MIKROTIK_PROFILE=default

# SERVER CONFIG
PORT=3000
WEBHOOK_SECRET=your_secret_if_any
